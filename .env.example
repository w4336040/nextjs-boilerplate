# Alibaba.com Open Platform app credentials
ALIBABA_APP_KEY=your_app_key_here
ALIBABA_APP_SECRET=your_new_app_secret_here

# Must match the callback URL configured in Alibaba Open Platform
ALIBABA_REDIRECT_URI=http://127.0.0.1:8765/callback

# Get these exact URLs from the official Alibaba Open Platform OAuth docs
ALIBABA_AUTH_URL=https://open.alibaba.com/oauth/authorize
ALIBABA_TOKEN_URL=https://open.alibaba.com/oauth/token

# Optional. Use the scopes shown in your app authorization docs, if required.
ALIBABA_SCOPE=

# Optional state value to protect the callback from cross-request mixups.
ALIBABA_STATE=local-dev

