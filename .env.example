ALIBABA_APP_KEY=your_app_key_here
ALIBABA_APP_SECRET=your_new_app_secret_here
ALIBABA_REDIRECT_URI=https://api.viecart.com/api/alibaba/oauth/callback
ALIBABA_AUTH_URL=https://open-api.alibaba.com/oauth/authorize?force_auth=true
ALIBABA_TOKEN_URL=https://open-api.alibaba.com/rest/auth/token/create
ALIBABA_SCOPE=
ALIBABA_STATE=production
ALIBABA_AUTH_STATE_PARAM=State

# Alibaba SELF_APP / OpenAPI debug options.
ALIBABA_TOKEN_REQUEST_FORMAT=iop
ALIBABA_OPENAPI_GATEWAY_URL=https://eco.taobao.com/router/rest
ALIBABA_TOP_SIGN_METHOD=hmac
ALIBABA_TOP_SESSION=
ALIBABA_IOP_GATEWAY_URL=https://open-api.alibaba.com/rest
ALIBABA_IOP_SIGN_METHOD=sha256
